# Key.properties template for signing the release APK
# Copy this file to 'key.properties' and fill in your values
# DO NOT commit the actual key.properties file to version control!

# Path to your keystore file (relative to android/app or absolute path)
storeFile=../keystore/release-key.jks

# Keystore password
storePassword=YOUR_KEYSTORE_PASSWORD

# Key alias (name you gave to the key when creating it)
keyAlias=tripspending

# Key password
keyPassword=YOUR_KEY_PASSWORD
